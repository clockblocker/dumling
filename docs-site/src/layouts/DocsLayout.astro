---
import type { NavItem } from "../lib/navigation";

interface Props {
	currentHref: string;
	description?: string;
	navItems: NavItem[];
	title: string;
}

const { currentHref, description, navItems, title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description ?? title} />
		<title>{title} | dumling</title>
	</head>
	<body>
		<header class="site-header">
			<a class="brand" href="/">dumling</a>
			<nav aria-label="Docs">
				{
					navItems.map((item) => (
						<a
							aria-current={item.href === currentHref ? "page" : undefined}
							href={item.href}
						>
							{item.title}
						</a>
					))
				}
			</nav>
		</header>
		<main>
			<slot />
		</main>
	</body>
</html>

<style is:global>
	:root {
		color: #202124;
		background: #fbfaf7;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
			"Segoe UI", sans-serif;
		line-height: 1.6;
	}

	body {
		margin: 0;
	}

	a {
		color: #0f5f7a;
		text-decoration-thickness: 0.08em;
		text-underline-offset: 0.18em;
	}

	strong {
		font-weight: 700;
	}

	em {
		color: #34312d;
		font-style: italic;
	}

	.site-header {
		align-items: center;
		border-bottom: 1px solid #ddd8cf;
		display: flex;
		gap: 2rem;
		justify-content: space-between;
		padding: 0.85rem clamp(1rem, 4vw, 3rem);
	}

	.brand {
		color: #202124;
		font-weight: 700;
		text-decoration: none;
	}

	nav {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem 1rem;
		justify-content: flex-end;
	}

	nav a {
		color: #4e4a43;
		text-decoration: none;
	}

	nav a[aria-current="page"] {
		color: #202124;
		font-weight: 650;
	}

	main {
		margin: 0 auto;
		max-width: 74ch;
		padding: clamp(1.5rem, 5vw, 4rem) clamp(1rem, 4vw, 2rem);
	}

	h1,
	h2,
	h3 {
		line-height: 1.2;
	}

	h1 {
		font-size: 2.25rem;
		margin: 0 0 1rem;
	}

	h2 {
		border-top: 1px solid #e3ded6;
		font-size: 1.35rem;
		margin-top: 2.25rem;
		padding-top: 1.5rem;
	}

	code {
		background: #f0ede7;
		border: 1px solid #ded8cf;
		border-radius: 3px;
		color: #2d2a25;
		font-size: 0.9em;
		padding: 0.03rem 0.22rem;
	}

	pre {
		background: #202124;
		border-radius: 8px;
		color: #f8f7f3;
		overflow-x: auto;
		padding: 1rem;
	}

	pre code {
		border: 0;
		background: transparent;
		color: inherit;
		padding: 0;
	}

	blockquote {
		border-left: 3px solid #c8bfae;
		color: #34312d;
		margin: 1.25rem 0;
		padding: 0.15rem 0 0.15rem 1rem;
	}

	blockquote p {
		margin: 0;
	}

	li {
		margin: 0.35rem 0;
	}

	table {
		border-collapse: collapse;
		display: block;
		overflow-x: auto;
		width: 100%;
	}

	th,
	td {
		border-bottom: 1px solid #e3ded6;
		padding: 0.45rem 0.7rem;
		text-align: left;
		vertical-align: top;
	}

	@media (max-width: 720px) {
		.site-header {
			align-items: flex-start;
			flex-direction: column;
			gap: 0.75rem;
		}

		nav {
			justify-content: flex-start;
		}
	}
</style>
