---
import type { NavItem } from "../lib/navigation";

interface Props {
	currentHref: string;
	description?: string;
	navItems: NavItem[];
	title: string;
}

const { currentHref, description, navItems, title } = Astro.props;

function isDescendantRoute(ancestorRouteId: string, routeId: string): boolean {
	return (
		ancestorRouteId !== "index" &&
		routeId.startsWith(`${ancestorRouteId}/`)
	);
}

function topLevelNavItems(items: NavItem[]): NavItem[] {
	return items.filter(
		(item) =>
			!items.some(
				(candidate) =>
					candidate.routeId !== item.routeId &&
					isDescendantRoute(candidate.routeId, item.routeId),
			),
	);
}

function directChildrenFor(parent: NavItem, items: NavItem[]): NavItem[] {
	return items.filter((item) => {
		if (!isDescendantRoute(parent.routeId, item.routeId)) {
			return false;
		}

		const relativeRouteId = item.routeId.slice(parent.routeId.length + 1);
		return !relativeRouteId.includes("/");
	});
}

function descendantsFor(parent: NavItem, items: NavItem[]): NavItem[] {
	return items.filter((item) => isDescendantRoute(parent.routeId, item.routeId));
}

function currentItemIsWithin(item: NavItem, items: NavItem[], href: string): boolean {
	return (
		item.href === href ||
		descendantsFor(item, items).some((candidate) => candidate.href === href)
	);
}

const headerItems = topLevelNavItems(navItems);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description ?? title} />
		<title>{title} | dumling</title>
	</head>
	<body>
		<header class="site-header">
			<a class="brand" href="/">dumling</a>
			<nav aria-label="Docs">
				{
					headerItems.map((item) => {
						const directChildren = directChildrenFor(item, navItems);
						const isActiveGroup = currentItemIsWithin(
							item,
							navItems,
							currentHref,
						);

						if (directChildren.length === 0) {
							return (
								<a
									aria-current={
										item.href === currentHref ? "page" : undefined
									}
									href={item.href}
								>
									{item.title}
								</a>
							);
						}

						return (
							<details class="nav-group">
								<summary class:list={["nav-summary", isActiveGroup && "is-active"]}>
									<span>{item.title}</span>
									<span aria-hidden="true" class="nav-caret">
										▾
									</span>
								</summary>
								<div class="nav-panel">
									<a
										aria-current={
											item.href === currentHref ? "page" : undefined
										}
										class="nav-panel-link nav-overview"
										href={item.href}
									>
										Overview
									</a>
									{
										directChildren.map((child) => {
											const nestedChildren = directChildrenFor(
												child,
												navItems,
											);
											const isActiveSubgroup = currentItemIsWithin(
												child,
												navItems,
												currentHref,
											);

											if (nestedChildren.length === 0) {
												return (
													<a
														aria-current={
															child.href === currentHref
																? "page"
																: undefined
														}
														class="nav-panel-link"
														href={child.href}
													>
														{child.title}
													</a>
												);
											}

											return (
												<details
													class="nav-subgroup"
													open={isActiveSubgroup}
												>
													<summary
														class:list={[
															"nav-subgroup-summary",
															isActiveSubgroup && "is-active",
														]}
													>
														<span>{child.title}</span>
														<span aria-hidden="true" class="nav-caret">
															▾
														</span>
													</summary>
													<div class="nav-subgroup-panel">
														<a
															aria-current={
																child.href === currentHref
																	? "page"
																	: undefined
															}
															class="nav-panel-link nav-section-link"
															href={child.href}
														>
															Overview
														</a>
														{
															nestedChildren.map((nestedChild) => (
																<a
																	aria-current={
																		nestedChild.href === currentHref
																			? "page"
																			: undefined
																	}
																	class="nav-panel-link nav-nested-link"
																	href={nestedChild.href}
																>
																	{nestedChild.title}
																</a>
															))
														}
													</div>
												</details>
											);
										})
									}
								</div>
							</details>
						);
					})
				}
			</nav>
		</header>
		<main>
			<slot />
		</main>
	</body>
</html>

<style is:global>
	:root {
		color: #202124;
		background: #fbfaf7;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
			"Segoe UI", sans-serif;
		line-height: 1.6;
	}

	body {
		margin: 0;
	}

	a {
		color: #0f5f7a;
		text-decoration-thickness: 0.08em;
		text-underline-offset: 0.18em;
	}

	strong {
		font-weight: 700;
	}

	em {
		color: #34312d;
		font-style: italic;
	}

	.site-header {
		align-items: center;
		border-bottom: 1px solid #ddd8cf;
		display: flex;
		gap: 2rem;
		justify-content: space-between;
		padding: 0.85rem clamp(1rem, 4vw, 3rem);
	}

	.brand {
		color: #202124;
		font-weight: 700;
		text-decoration: none;
	}

	nav {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem 1rem;
		justify-content: flex-end;
	}

	nav a,
	.nav-summary {
		color: #4e4a43;
		text-decoration: none;
	}

	nav a[aria-current="page"],
	.nav-summary.is-active {
		color: #202124;
		font-weight: 650;
	}

	.nav-group {
		position: relative;
	}

	.nav-summary {
		align-items: center;
		border-radius: 999px;
		cursor: pointer;
		display: inline-flex;
		gap: 0.35rem;
		list-style: none;
		padding: 0.2rem 0.55rem;
	}

	.nav-summary::-webkit-details-marker {
		display: none;
	}

	.nav-caret {
		font-size: 0.75rem;
		transition: transform 140ms ease;
	}

	.nav-group[open] .nav-caret {
		transform: rotate(180deg);
	}

	.nav-panel {
		background: #fffdfa;
		border: 1px solid #ddd8cf;
		border-radius: 10px;
		box-shadow: 0 10px 30px rgba(32, 33, 36, 0.1);
		display: grid;
		gap: 0.45rem;
		min-width: 18rem;
		max-width: min(24rem, calc(100vw - 2rem));
		padding: 0.65rem;
		position: absolute;
		left: 0;
		top: calc(100% + 0.65rem);
		z-index: 10;
	}

	.nav-panel-link {
		border-radius: 7px;
		display: block;
		padding: 0.4rem 0.55rem;
		text-decoration: none;
	}

	.nav-panel-link:hover,
	.nav-summary:hover {
		color: #202124;
	}

	.nav-summary:hover {
		background: #f4efe5;
	}

	.nav-panel-link:hover {
		background: #f4efe5;
	}

	.nav-overview {
		border-bottom: 1px solid #ece5d9;
		font-weight: 650;
		margin-bottom: 0.2rem;
		padding-bottom: 0.55rem;
	}

	.nav-subgroup {
		border-top: 1px solid #f0e9de;
		padding-top: 0.35rem;
	}

	.nav-subgroup-summary {
		align-items: center;
		border-radius: 7px;
		cursor: pointer;
		display: flex;
		font-weight: 650;
		justify-content: space-between;
		list-style: none;
		padding: 0.4rem 0.55rem;
	}

	.nav-subgroup-summary::-webkit-details-marker {
		display: none;
	}

	.nav-subgroup-summary:hover {
		background: #f4efe5;
		color: #202124;
	}

	.nav-subgroup-summary.is-active {
		color: #202124;
	}

	.nav-subgroup-panel {
		display: grid;
		gap: 0.15rem;
		margin-top: 0.2rem;
	}

	.nav-section-link {
		font-weight: 650;
	}

	.nav-nested-link {
		font-size: 0.95rem;
		padding-left: 1rem;
	}

	main {
		margin: 0 auto;
		max-width: 74ch;
		padding: clamp(1.5rem, 5vw, 4rem) clamp(1rem, 4vw, 2rem);
	}

	h1,
	h2,
	h3 {
		line-height: 1.2;
	}

	h1 {
		font-size: 2.25rem;
		margin: 0 0 1rem;
	}

	h2 {
		border-top: 1px solid #e3ded6;
		font-size: 1.35rem;
		margin-top: 2.25rem;
		padding-top: 1.5rem;
	}

	code {
		background: #f0ede7;
		border: 1px solid #ded8cf;
		border-radius: 3px;
		color: #2d2a25;
		font-size: 0.9em;
		padding: 0.03rem 0.22rem;
	}

	pre {
		background: #202124;
		border-radius: 8px;
		color: #f8f7f3;
		overflow-x: auto;
		padding: 1rem;
	}

	pre code {
		border: 0;
		background: transparent;
		color: inherit;
		padding: 0;
	}

	blockquote {
		border-left: 3px solid #c8bfae;
		color: #34312d;
		margin: 1.25rem 0;
		padding: 0.15rem 0 0.15rem 1rem;
	}

	blockquote p {
		margin: 0;
	}

	li {
		margin: 0.35rem 0;
	}

	table {
		border-collapse: collapse;
		display: block;
		overflow-x: auto;
		width: 100%;
	}

	th,
	td {
		border-bottom: 1px solid #e3ded6;
		padding: 0.45rem 0.7rem;
		text-align: left;
		vertical-align: top;
	}

	@media (max-width: 720px) {
		.site-header {
			align-items: flex-start;
			flex-direction: column;
			gap: 0.75rem;
		}

		nav {
			justify-content: flex-start;
		}

		.nav-group {
			width: 100%;
		}

		.nav-panel {
			box-shadow: none;
			min-width: 0;
			position: static;
		}
	}
</style>
