---
import { getCollection, render } from "astro:content";
import DocsLayout from "../../layouts/DocsLayout.astro";
import {
	hrefForPage,
	htmlRouteSegmentsForPage,
	navItemsForDocs,
} from "../../lib/navigation";

export async function getStaticPaths() {
	const docs = await getCollection("docs");
	const entities = await getCollection("entities");
	const pages = [...docs, ...entities];

	return pages
		.filter(
			(page) =>
				page.data.htmlRoute !== undefined &&
				htmlRouteSegmentsForPage(page).length === 2,
		)
		.map((page) => {
			const [scope, routePage] = htmlRouteSegmentsForPage(page);
			return {
				params: { page: routePage, scope },
				props: { page },
			};
		});
}

const { page } = Astro.props;
const docs = await getCollection("docs");
const navItems = navItemsForDocs(docs);
const { Content } = await render(page);
const currentHref = hrefForPage(page);
---

<DocsLayout
	currentHref={currentHref}
	description={page.data.description}
	navItems={navItems}
	title={page.data.title}
>
	<Content />
</DocsLayout>
