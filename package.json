{
	"name": "dumling",
	"version": "0.1.1",
	"description": "Typesafe schemas and operations for learner-facing linguistic segmentation.",
	"type": "module",
	"packageManager": "bun@1.3.0",
	"license": "MIT",
	"sideEffects": false,
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": ["dist", "README.md", "LICENSE"],
	"engines": {
		"node": ">=20"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/clockblocker/dumling.git"
	},
	"bugs": {
		"url": "https://github.com/clockblocker/dumling/issues"
	},
	"homepage": "https://github.com/clockblocker/dumling#readme",
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "bun run build:js && bun run build:types",
		"build:js": "rm -rf dist && bun build src/index.ts --outfile dist/index.js --format esm --target node --packages external",
		"build:types": "tsgo -p tsconfig.build.json",
		"check": "tsgo -p tsconfig.json --noEmit",
		"fix": "bunx @biomejs/biome check --write .",
		"generate:readme": "bun run generate-readme/generate-readme.ts",
		"knip": "bunx knip",
		"lint": "bunx @biomejs/biome check .",
		"prepack": "bun run generate:readme && bun run build",
		"test": "bun test"
	},
	"dependencies": {
		"neverthrow": "^8.2.0",
		"zod": "3.25.76"
	},
	"devDependencies": {
		"@typescript/native-preview": "7.0.0-dev.20260416.2",
		"@biomejs/biome": "^1.9.4",
		"@types/node": "^24.5.2",
		"bun-types": "1.3.0",
		"knip": "^5.82.1"
	}
}
