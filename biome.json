{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"files": {
		"ignore": [
			"dist",
			"docs-site/.astro",
			"docs-site/dist",
			"docs-site/node_modules",
			"docs-site/public/*.md",
			"docs-site/public/nav.json",
			"docs-site/src/generated",
			"node_modules",
			"src/lu/test.ts"
		]
	},
	"formatter": {
		"enabled": true,
		"ignore": ["generate-readme/examples/**/*.ts"],
		"indentStyle": "tab",
		"indentWidth": 4,
		"lineEnding": "lf",
		"lineWidth": 80
	},
	"organizeImports": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"ignore": ["generate-readme/examples/**/*.ts"]
	}
}
